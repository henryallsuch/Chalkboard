    {
      "name": "XML Meta tag",
      "scope": "declaration.tag, declaration.tag entity, meta.tag, meta.tag entity",
      "settings": {
        "foreground": "#efac32"
      }
    },
    {
      "name": "Html Element",
      "scope": "text.html.basic meta.tag",
      "settings": {
        "foreground": "#efac32"
      }
    },
    {
      "name": "Html Tag Name",
      "scope": "text.html.basic entity.name.tag",
      "settings": {
        "foreground": "#efac32"
      }
    },
    {
