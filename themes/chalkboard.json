  "tokenColors": [
    {
      "name": "Global settings",
      "settings": {
        "background": "#0f3326",
        "foreground": "#e6e1c4"
      }
    },
    {
      "name": "Operator",
      "scope": "keyword.operator -keyword.operator.dereference",
      "settings": {
        "foreground": "#bbd7c1"
      }
    },
    {
      "name": "Comment",
      "scope": "comment",
      "settings": {
        "foreground": "#efcb43"
      }
    },
    {
      "name": "HTML Entity",
      "scope": "constant.character.entity",
      "settings": {
        "foreground": "#66ccff"
      }
    },
    {
      "name": "Numeric",
      "scope": "constant.numeric",
      "settings": {
        "foreground": "#6F59C2"
      }
    },
    {
      "name": "Double Quoted",
      "scope": "string.quoted.double",
      "settings": {
        "foreground": "#C4622D"
      }
    },
    {
      "name": "Single Quoted",
      "scope": "string.quoted.single",
      "settings": {
        "foreground": "#C4622D"
      }
    },
    {
      "name": "Language Constant",
      "scope": "constant.language",
      "settings": {
        "foreground": "#0092d1"
      }
    },
    {
      "name": "Class",
      "scope": "meta.class.identifier, entity.name.type.class, support.class",
      "settings": {
        "foreground": "#6FC1D2"
      }
    },
    {
      "name": "Inherited class",
      "scope": "entity.other.inherited-class",
      "settings": {
        "foreground": "#6FC1D2"
      }
    },
    {
      "name": "Storage type",
      "scope": "storage.type",
      "settings": {
        "foreground": "#0092d1"
      }
    },
    {
      "name": "Variable",
      "scope": "variable, punctuation.definition.variable",
      "settings": {
        "foreground": "#6c99bb"
      }
    },
    {
      "name": "Keyword",
      "scope": "keyword",
      "settings": {
        "foreground": "#0092d1"
      }
    },
    {
      "name": "Keyword other",
      "scope": "keyword.other",
      "settings": {
        "foreground": "#0092d1"
      }
    },
    {
      "name": "Method",
      "scope": "meta.method.identifier, meta.method-call, meta.method.declaration",
      "settings": {
        "foreground": "#13FFA3"
