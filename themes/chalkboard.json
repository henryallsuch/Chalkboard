      "settings": {
        "foreground": "#B6B8FE"
      }
    },
    {
      "name": "Function definition",
      "scope": "meta.function entity.name.function",
      "settings": {
        "foreground": "#41b644"
      }
    },
    {
      "name": "Function call",
      "scope": "meta.function-call, support.function.name",
      "settings": {
        "foreground": "#41b644"
      }
    },
    {
      "name": "Function arguments",
      "scope": "meta.function-call.arguments, variable.parameter",
      "settings": {
        "foreground": "#e6e1c4"
      }
    },
    {
      "name": "Support function",
      "scope": "support.function",
      "settings": {
        "foreground": "#41b645"
      }
    },
    {
      "name": "Builtin function",
      "scope": "support.function.builtin",
      "settings": {
        "foreground": "#E0A1FF"
      }
    },
    {
      "name": "Magic function",
      "scope": "support.function.magic",
      "settings": {
        "foreground": "#41b644"
      }
    },
    {
      "name": "XML Doctype",
